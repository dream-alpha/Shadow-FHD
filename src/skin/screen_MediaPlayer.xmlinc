		<widget  enableWrapAround="1" name="filelist" position="165,170" scrollbarMode="showOnDemand" size="760,550" transparent="1"/>
		<eLabel backgroundColor="background" font="Bold;34" halign="center" position="1000,100" size="760,45" text="P L A Y L I S T" transparent="1"/>
