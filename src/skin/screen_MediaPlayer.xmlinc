	<screen backgroundColor="background" flags="wfNoBorder" name="MediaPlayer" position="center,center" size="1920,1080" title="MediaPlayer">
		<layout name="Title_Time"/>
		<layout name="Soundplayer"/>
		<eLabel backgroundColor="background" position="80,790" size="1760,200" zPosition="-1"/>
		<eLabel backgroundColor="background" position="145,90" size="800,650" zPosition="-1"/>
		<eLabel backgroundColor="background" position="980,90" size="800,650" zPosition="-1"/>
		<eLabel backgroundColor="background" font="Bold;34" halign="center" position="165,100" size="760,45" text="F I L E L I S T" transparent="1"/>
