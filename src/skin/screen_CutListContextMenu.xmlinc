	<screen backgroundColor="background" flags="wfNoBorder" name="CutListContextMenu" position="0,0" size="700,1080" title="Cutlist Menu">
		<xmlinc name="screenpart_Title_small" $source="Title" $menu_pixmap="Shadow-FHD/images/movies.svg"/>
		<widget  enableWrapAround="1" position="20,120" render="Listbox" scrollbarMode="showNever" size="660,680" source="menu" transparent="1">
			<convert type="StringList"/>
		</widget>
		<xmlinc name="screenpart_menu_arrow_down"/>
	</screen>
