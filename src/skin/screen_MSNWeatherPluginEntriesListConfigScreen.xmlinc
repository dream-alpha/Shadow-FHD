		<widget font="Bold;30" halign="right" position="720,170" render="Label" size="300,35" source="degreetype"/>
		<widget enableWrapAround="1" name="entrylist" position="20,220" scrollbarMode="showOnDemand" size="1000,150"/>
		<widget backgroundColor="CursorBackground" font="Regular;26" foregroundColor="HeaderForeground" halign="center" position="0,390" render="Label" size="347,50" source="key_green" valign="center"/>
		<widget backgroundColor="CursorBackground" font="Regular;26" foregroundColor="HeaderForeground" halign="center" position="347,390" render="Label" size="346,50" source="key_yellow" valign="center"/>
		<widget backgroundColor="CursorBackground" font="Regular;26" foregroundColor="HeaderForeground" halign="center" position="693,390" render="Label" size="347,50" source="key_blue" valign="center"/>
		<eLabel backgroundColor="green" position="0,440" size="347,10"/>
