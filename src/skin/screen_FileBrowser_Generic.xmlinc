	<screen backgroundColor="background" flags="wfNoBorder" name="FileBrowser_Generic" position="0,center" size="700,1080">
		<xmlinc name="screenpart_Title_small" $source="Title" $menu_pixmap="Shadow-FHD/extensions/directory.svg"/>
		<eLabel backgroundColor="background" font="Bold;32" position="50,195" size="600,36" text="File Browser" transparent="1" valign="centerOrBottom"/>
		<widget  enableWrapAround="1" name="filelist" position="20,120" scrollbarMode="showOnDemand" size="660,680" transparent="1"/>
		<eLabel backgroundColor="grey" position="20,880" size="660,1"/>
		<widget  font="Regular;28" foregroundColors="Heading,yellow,green" halign="center" name="status" position="20,900" size="660,70" transparent="1" valign="center"/>
		<eLabel backgroundColor="green" position="0,1070" size="700,10"/>
		<widget backgroundColor="gradient" font="Regular;26" halign="center" name="key_green" position="0,1000" size="700,60" transparent="1" valign="center"/>
	</screen>
