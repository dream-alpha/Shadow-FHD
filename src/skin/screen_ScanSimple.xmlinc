	<screen backgroundColor="background" flags="wfNoBorder" name="ScanSimple" position="0,center" size="700,1080" title="Service scan">
		<xmlinc name="screenpart_Title_small" $source="Title" $menu_pixmap="Shadow-FHD/images/scan.svg"/>
		<layout name="smallbutton_close"/>
		<widget backgroundColor="gradient" enableWrapAround="1" name="config" position="20,120" scrollbarMode="showOnDemand" size="660,680" transparent="1"/>
		<eLabel backgroundColor="grey" position="20,900" size="660,1"/>
		<widget backgroundColor="gradient" font="Regular;28" foregroundColor="Heading" halign="center" name="header" position="20,910" size="660,35" transparent="1"/>
		<widget backgroundColor="gradient" font="Regular;28" foregroundColor="Heading" halign="center" name="footer" position="20,950" size="660,35" transparent="1"/>
	</screen>
